# Server port
PORT=4000

# Razorpay keys (leave empty to enable mock payment flow)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Firebase Realtime Database
# Example (from Firebase console):
# FIREBASE_DATABASE_URL=https://<project-id>.firebaseio.com?...
FIREBASE_DATABASE_URL=

# Option A (local/dev): paste service account JSON as a single-line env string
FIREBASE_SERVICE_ACCOUNT_JSON=

# SMTP (Nodemailer). Leave empty to log emails instead.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-app-password
EMAIL_FROM=your-email@gmail.com

# Twilio (optional). Leave empty to log SMS instead.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Reminder tolerance window around exactly 1 hour-before time (minutes)
REMINDER_LOOKAHEAD_MINUTES=5

