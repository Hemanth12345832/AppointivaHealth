<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Book Appointment"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tvBookingDoctorName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Doctor: Dr. Name"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvDoctorAvailability"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Fetching availability..."
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etBookingDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Select Date (YYYY-MM-DD)"
        android:focusable="false"
        android:inputType="none"
        android:drawableEnd="@android:drawable/ic_menu_my_calendar"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etBookingTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Select Time (HH:MM)"
        android:focusable="false"
        android:inputType="none"
        android:drawableEnd="@android:drawable/ic_menu_recent_history"
        android:layout_marginBottom="32dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmBooking"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Confirm Booking"
        android:textSize="18sp" />

</LinearLayout>
