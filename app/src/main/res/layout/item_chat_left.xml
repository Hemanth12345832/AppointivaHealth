<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="start"
    android:padding="4dp"
    android:paddingStart="8dp"
    android:paddingEnd="48dp">
    <!-- Padding end creates space so bubbles don't stretch fully right -->

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/chat_bubble_left"
        android:padding="12dp"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivAttachmentLeft"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:id="@+id/llPdfAttachmentLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#0A000000"
            android:padding="8dp"
            android:visibility="gone"
            android:layout_marginBottom="4dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="@color/primary" />
            <TextView
                android:id="@+id/tvPdfNameLeft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:layout_marginStart="8dp"
                android:maxWidth="150dp"
                android:ellipsize="end"
                android:textStyle="bold"
                android:maxLines="1"
                android:text="document.pdf" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvMessageLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:text="Left Message" />

        <TextView
            android:id="@+id/tvTimestampLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:layout_marginTop="4dp"
            android:text="12:00 PM"
            android:layout_gravity="end"/>
    </LinearLayout>

</LinearLayout>
