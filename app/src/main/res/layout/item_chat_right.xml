<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="end"
    android:padding="4dp"
    android:paddingStart="48dp"
    android:paddingEnd="8dp">
    <!-- Padding start creates space so bubbles don't stretch fully left -->

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/chat_bubble_right"
        android:padding="12dp"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivAttachmentRight"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:id="@+id/llPdfAttachmentRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1AFFFFFF"
            android:padding="8dp"
            android:visibility="gone"
            android:layout_marginBottom="4dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="@color/white" />
            <TextView
                android:id="@+id/tvPdfNameRight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:layout_marginStart="8dp"
                android:maxWidth="150dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="document.pdf" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvMessageRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:text="Right Message" />

        <TextView
            android:id="@+id/tvTimestampRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E0E0E0"
            android:textSize="10sp"
            android:layout_marginTop="4dp"
            android:text="12:00 PM"
            android:layout_gravity="end"/>
    </LinearLayout>

</LinearLayout>
