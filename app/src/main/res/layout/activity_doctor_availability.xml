<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarAvailability"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="Availability Settings"
            app:titleTextColor="@color/white" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set Your Schedule"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter standard time slots e.g., '10:00 AM - 1:00 PM, 4:00 PM - 7:00 PM' or leave blank if unavailable."
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="24dp"/>

            <!-- Monday -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monday"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etMonTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. 10-1, 4-7"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <!-- Tuesday -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tuesday"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etTueTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. 10-1, 4-7"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <!-- Wednesday -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wednesday"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etWedTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. 10-1, 4-7"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <!-- Thursday -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thursday"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etThuTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. 10-1, 4-7"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <!-- Friday -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Friday"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etFriTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. 10-1, 4-7"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <!-- Saturday -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saturday"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etSatTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. 10-1"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <!-- Sunday -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sunday"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etSunTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Leave blank if unavailable"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnSaveAvailability"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save Availability"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"
                android:layout_marginBottom="16dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
