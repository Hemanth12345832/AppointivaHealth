<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarAppointmentMgt"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:title="Manage Appointments"
        app:titleTextColor="@color/white" />

    <!-- Filters -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/white"
        android:elevation="2dp">

        <EditText
            android:id="@+id/etSearchPatient"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Search Patient Name"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="8dp"
            android:background="@drawable/edit_text_bg"
            android:padding="12dp"
            android:textSize="14sp"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/etFilterDate"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:hint="Date"
            android:focusable="false"
            android:clickable="true"
            android:drawableEnd="@android:drawable/ic_menu_agenda"
            android:drawablePadding="8dp"
            android:background="@drawable/edit_text_bg"
            android:padding="12dp"
            android:textSize="14sp"/>

    </LinearLayout>

    <!-- No Appointments State -->
    <TextView
        android:id="@+id/tvNoAppointments"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No Appointments Found"
        android:textSize="16sp"
        android:visibility="gone"
        android:textColor="@color/text_secondary"
        android:layout_gravity="center"
        android:layout_marginTop="32dp"/>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAppointmentManagement"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="8dp"/>

</LinearLayout>
